{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": [
    "app/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}",
    "types/**/*.{ts,tsx}",
    "utils/**/*.{ts,tsx}"
  ],
  "ignore": [
    "hooks/useOnlineStatus.ts",
    "hooks/usePWAInstall.ts",
    "components/ui/index.ts",
    "components/ui/InstallPrompt.tsx",
    "components/ui/OfflineIndicator.tsx",
    "types/index.ts",
    "components/party/AddContentModal.tsx",
    "components/party/DeleteConfirmDialog.tsx",
    "components/party/InviteModal.tsx",
    "components/party/NoteEditModal.tsx",
    "components/party/NoteViewModal.tsx",
    "components/party/QueueItemActionsSheet.tsx"
  ],
  "ignoreDependencies": [
    "@capacitor/android",
    "@capacitor/core",
    "@capacitor/ios",
    "@capacitor/push-notifications",
    "postcss",
    "tailwindcss",
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github"
  ],
  "ignoreBinaries": ["doppler"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "off"
  },
  "next": {
    "entry": ["app/**/*.{ts,tsx}", "next.config.ts"]
  },
  "vitest": {
    "entry": ["**/*.{test,spec}.{ts,tsx}", "vitest.config.ts"]
  }
}
